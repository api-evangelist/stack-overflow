                "value": "",
                "type": "query",
                "description": "Filter to control which fields are returned"
              },
              {
                "name": "site",
                "value": "",
                "type": "query",
                "description": "Stack Exchange site identifier (use stackoverflow for Stack Overflow)"
              }
